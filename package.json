{
  "name": "ai-business-english-mvp",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "dev:log": "mkdir -p logs; next dev 2>&1 | tee logs/dev.log",
    "dev:clean": "kill -9 $(lsof -ti :3000) 2>/dev/null || true; rm -rf .next; next dev",
    "build": "next build",
    "start": "next start",
    "start:clean": "kill -9 $(lsof -ti :3000) 2>/dev/null || true; rm -rf .next; next build && next start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@supabase/supabase-js": "^2.45.4",
    "next": "14.2.5",
    "openai": "^6.33.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  }
}
