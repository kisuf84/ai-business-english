# Server-side Supabase URL used by API routes and server helpers.
SUPABASE_URL=

# Server-side only. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Required for browser auth and the /auth page in all environments, including Vercel production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side anon fallback for internal helpers. This does not replace NEXT_PUBLIC_* for browser auth.
SUPABASE_ANON_KEY=

OPENAI_API_KEY=
